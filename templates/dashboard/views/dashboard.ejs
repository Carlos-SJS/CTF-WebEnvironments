<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Employee Portal - Dashboard</title>
  <style>
    :root {
      --primary-color: <%= theme %>;
    }
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background-color: #f4f7f6;
      color: #333;
    }
    .header {
      background-color: var(--primary-color);
      color: white;
      padding: 15px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .header h1 {
      margin: 0;
      font-size: 24px;
    }
    .logout {
      color: white;
      text-decoration: none;
      font-weight: bold;
      background: rgba(255,255,255,0.2);
      padding: 8px 15px;
      border-radius: 4px;
    }
    .logout:hover {
      background: rgba(255,255,255,0.3);
    }
    .container {
      max-width: 1000px;
      margin: 40px auto;
      padding: 0 20px;
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 30px;
    }
    .card {
      background: white;
      border-radius: 8px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.05);
      padding: 20px;
    }
    .card h2 {
      margin-top: 0;
      border-bottom: 2px solid #eee;
      padding-bottom: 10px;
      color: var(--primary-color);
    }
    .profile-info p {
      margin: 10px 0;
    }
    .profile-info strong {
      display: inline-block;
      width: 100px;
      color: #666;
    }
    .message {
      background: #f9f9f9;
      padding: 15px;
      border-left: 4px solid var(--primary-color);
      margin-bottom: 15px;
      border-radius: 0 4px 4px 0;
    }
    .message-meta {
      font-size: 12px;
      color: #888;
      margin-bottom: 5px;
    }
    .no-messages {
      color: #888;
      font-style: italic;
    }
    .badge {
      display: inline-block;
      background: var(--primary-color);
      color: white;
      padding: 3px 8px;
      border-radius: 12px;
      font-size: 12px;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>Internal Dashboard</h1>
    <a href="?logout=true" class="logout">Logout</a>
  </div>

  <div class="container">
    <div class="card">
      <h2>Profile Details</h2>
      <div class="profile-info">
        <p><strong>Employee ID:</strong> <%= user.id %></p>
        <p><strong>Username:</strong> <%= user.username %></p>
        <p><strong>Department:</strong> <%= user.department %></p>
        <p><strong>Role:</strong> <span class="badge"><%= user.role %></span></p>
      </div>
    </div>

    <div class="card">
      <h2>Inbox Messages</h2>
      <% if (messages && messages.length > 0) { %>
        <% messages.forEach(function(msg) { %>
          <div class="message">
            <div class="message-meta">From Employee ID: <%= msg.sender_id %></div>
            <div class="message-content"><%= msg.content %></div>
          </div>
        <% }); %>
      <% } else { %>
        <p class="no-messages">Your inbox is empty.</p>
      <% } %>
    </div>
  </div>
</body>
</html>
